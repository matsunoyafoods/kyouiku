# === サーバー設定 ===
PORT=3000
JWT_SECRET=your-secret-key-change-this
NODE_ENV=production

# === OpenAI (ChatGPT) API ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# === LINE Messaging API ===
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# === 店舗別LINEグループID ===
# LINE_GROUP_店舗コード=グループID の形式で設定
# グループIDはBotをグループに招待した際のWebhookイベントから取得可能
LINE_GROUP_STORE001=Cxxxxxxxxxxxxxxxxxxxxx
LINE_GROUP_STORE002=Cxxxxxxxxxxxxxxxxxxxxx
LINE_GROUP_STORE003=Cxxxxxxxxxxxxxxxxxxxxx

# === 月末配信設定 ===
# cron式: 秒 分 時 日 月 曜日
# デフォルト: 毎月最終日の10:00
REPORT_CRON_SCHEDULE=0 10 28-31 * *
